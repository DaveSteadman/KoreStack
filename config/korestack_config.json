{
  "comment": "KoreStack suite configuration.",
  "paths": {
    "dataroot2":   "C:/Util/TestData",
    "dataroot":   "C:/Util/GithubRepos/KoreStack/Data",
    "korechat":   "korechat",
    "korecomms":  "korecomms",
    "koredata":   "koredata",
    "koredevice": "koredevice",
    "koreagent":  "koreagent",
    "koredocs":   "koredocs",
    "docs_data":  "KoreFiles"
  },
  "network": {
    "host": "127.0.0.1"
  },
  "services": {
    "korestack":         { "port": 19600, "enabled": true },
    "koreagent":         { "port": 19601, "enabled": true },
    "korechat":          { "port": 19602, "enabled": true },
    "koredatagateway":   { "port": 19603, "enabled": true },
    "korefeed":          { "port": 19604, "enabled": true },
    "korelibrary":       { "port": 19605, "enabled": true },
    "korerag":           { "port": 19606, "enabled": true },
    "korereference":     { "port": 19607, "enabled": true },
    "korescrape":        { "port": 19612, "enabled": true },
    "koregraph":         { "port": 19608, "enabled": true },
    "koredevicegateway": { "port": 19613, "enabled": true },
    "koredevicenumber":  { "port": 19614, "enabled": true },
    "koredevicedriver":  { "port": 19615, "enabled": true },
    "korecomms":         { "port": 19609, "enabled": true },
    "koredocs":          { "port": 19610, "enabled": true },
    "korecode":          { "port": 19611, "enabled": true }
  },
  "koredevicedriver": {
    "default_protocol":      "modbus-tcp",
    "default_vendor":        "Example Vendor",
    "default_poll_interval": 5
  },
  "mcp": {
    "connections": [
      {
        "name":            "KoreData",
        "service":         "koredatagateway",
        "path":            "/mcp",
        "enabled":         true,
        "purpose":         "reference search and retrieval across feeds, encyclopedia, library, and internal documents",
        "expected_prefix": "koredata_"
      },
      {
        "name":            "KoreDocs",
        "service":         "koredocs",
        "path":            "/mcp",
        "enabled":         true,
        "purpose":         "document navigation, structured editing, and KoreFile authoring",
        "expected_prefix": "koredocs_"
      }
    ]
  }
}

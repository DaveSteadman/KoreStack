{
  "id": "extract_llm_ollama",
  "name": "Extract Graph Triples (Ollama)",
  "description": "LLM-assisted extraction from a KoreLibrary book into KoreGraph using the configured Ollama backend.",
  "script": "extract_llm_ollama.py",
  "args": [
    {
      "flag": "--model",
      "type": "text",
      "default": "qwen3.5:27b",
      "help": "Ollama model name"
    },
    {
      "flag": "--chunk",
      "type": "int",
      "default": 3000,
      "help": "Chunk size in characters"
    },
    {
      "flag": "--dry-run",
      "type": "bool",
      "default": false,
      "help": "Extract without submitting to KoreGraph"
    }
  ]
}

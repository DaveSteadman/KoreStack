{
  "comment": "KoreStack suite configuration.",
  "paths": {
    "datacontrolroot": "C:/Util/GithubRepos/KoreStack/datacontrol",
    "datauserroot":    "C:/Util/GithubRepos/KoreStack/datauser",
    "korechat":        "korechat",
    "korecomms":       "korecomms",
    "koredata":        "koredata",
    "koredevice":      "koredevice",
    "koreagent":       "koreagent",
    "koredocs":        "koredocs",
    "docs_data":       "KoreFiles"
  },
  "network": {
    "host": "127.0.0.1"
  },
  "services": {
    "korestack":         { "port": 9600, "enabled": true },
    "koreagent":         { "port": 9601, "enabled": true },
    "korechat":          { "port": 9602, "enabled": true },
    "koredatagateway":   { "port": 9603, "enabled": true },
    "korefeed":          { "port": 9604, "enabled": true },
    "korelibrary":       { "port": 9605, "enabled": true },
    "korerag":           { "port": 9606, "enabled": true },
    "korereference":     { "port": 9607, "enabled": true },
    "korescrape":        { "port": 9612, "enabled": true },
    "koregraph":         { "port": 9608, "enabled": true },
    "koredevicegateway": { "port": 9613, "enabled": false },
    "koredevicenumber":  { "port": 9614, "enabled": false },
    "korecomms":         { "port": 9609, "enabled": true },
    "koredocs":          { "port": 9610, "enabled": true },
    "korecode":          { "port": 9611, "enabled": true }
  },
  "mcp": {
    "connections": [
      {
        "name":            "KoreData",
        "service":         "koredatagateway",
        "path":            "/mcp",
        "enabled":         true,
        "purpose":         "reference search and retrieval across feeds, encyclopedia, library, and internal documents",
        "expected_prefix": "koredata_"
      },
      {
        "name":            "KoreDocs",
        "service":         "koredocs",
        "path":            "/mcp",
        "enabled":         true,
        "purpose":         "document navigation, structured editing, and KoreFile authoring",
        "expected_prefix": "koredocs_"
      },
      {
        "name":            "KoreGraph",
        "service":         "koregraph",
        "path":            "/mcp",
        "enabled":         true,
        "purpose":         "concept graph search, traversal, and connection creation",
        "expected_prefix": "graph_connection_",
        "allowed_tools": [
          "graph_connection_search_vocab",
          "graph_connection_expand_concept",
          "graph_connection_expand_concept_by_term",
          "graph_connection_create",
          "graph_connection_create_many",
          "graph_connection_list",
          "graph_connection_delete"
        ]
      }
    ]
  }
}
